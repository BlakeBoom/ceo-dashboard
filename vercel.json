{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/((?!cron/).*)", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/cron/zoho-sync",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    },
    "api/cron/zoho-sync.js": {
      "maxDuration": 60
    }
  }
}
