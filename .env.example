# --- Neon Postgres ---
# Get this from Neon console → Connection string (pooled connection recommended)
DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# --- Auth ---
# 32+ char random secret. Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string
# Cookie lifetime
JWT_TTL_HOURS=12
# Set to "true" in production (HTTPS required)
COOKIE_SECURE=false

# --- Server ---
PORT=3000
NODE_ENV=development
# Comma-separated list of origins allowed for CORS (frontend served from same origin needs nothing)
ALLOWED_ORIGINS=

# --- Bootstrap admin (used by `npm run seed` for first-time setup) ---
SEED_ADMIN_EMAIL=admin@boomerangsa.com
SEED_ADMIN_PASSWORD=changeme-on-first-login
SEED_ADMIN_NAME=Platform Admin

# --- Zoho integration (Phase 2) ---
ZOHO_REGION=eu
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_PEOPLE_FORM_NAME=
ZOHO_ANALYTICS_WORKSPACE_ID=
