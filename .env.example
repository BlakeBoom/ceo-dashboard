# --- Auth ---
# 32+ char random secret. Generate with: openssl rand -base64 48
JWT_SECRET=oeI6kjEhFh1OeZdZqsaf64JB9dJKj/XbQ3w4cy94kYeVR4vftgd0817PpB/syNWT
# Cookie lifetime
JWT_TTL_HOURS=12
# Set to "true" in production (HTTPS required)
COOKIE_SECURE=false

# --- Server ---
PORT=3000
NODE_ENV=development
# Comma-separated list of origins allowed for CORS (frontend served from same origin needs nothing)
ALLOWED_ORIGINS=

# --- Bootstrap admin (used by `npm run seed` for first-time setup) ---
SEED_ADMIN_EMAIL=blakef@boomerangsa.com
SEED_ADMIN_PASSWORD=FpmWJHKlEhsFyJAeFNrSS8BPlp7k0FNAmVZiM/WztJYNZyTWgm1IwL9HkurFcvkj
SEED_ADMIN_NAME=Platform Admin

# --- Zoho integration (Phase 2) ---
# Region matches your Zoho data centre: com (US), eu (EU), in (India), com.au (AU), sa (Saudi)
ZOHO_REGION=com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_PEOPLE_FORM_NAME=
ZOHO_ANALYTICS_WORKSPACE_ID=

# --- Vercel Cron ---
# Random secret to authenticate cron invocations. Vercel injects this as the
# Authorization header on scheduled cron requests.
# Generate with: openssl rand -base64 32
CRON_SECRET=
